---
import Base from "../layouts/Base.astro"

const base = import.meta.env.BASE_URL
const flow = [
  ["01", "Plan", "Keep at most three explicit branches."],
  ["02", "Select", "Name the smallest decisive test."],
  ["03", "Act", "Use a raw tool or persistent PTY."],
  ["04", "Observe", "Project the real settlement automatically."],
  ["05", "Verify", "Run a milestone or final oracle."],
  ["06", "Decide", "Continue, reflect once, switch, or finish."],
]

const decisions = [
  {
    title: "Persistent interactive sessions",
    shipped: "Four generic PTY operations keep GDB, REPL, shell, and remote-service state alive across model turns.",
    why: "Interactive security interfaces improved CTF agent performance, while model-oriented interfaces beat raw human-oriented tooling.",
    sources: [["EnIGMA", "https://arxiv.org/abs/2409.16165"], ["SWE-agent", "https://arxiv.org/abs/2405.15793"]],
  },
  {
    title: "One bounded operator by default",
    shipped: "One primary operator plans, acts, observes, and verifies with three open branches and deterministic retry limits.",
    why: "Strong simple ReAct-and-plan baselines make additional orchestration something that must earn its cost.",
    sources: [["ReAct", "https://arxiv.org/abs/2210.03629"], ["Plain CTF agents", "https://arxiv.org/abs/2412.02776"], ["Effective agents", "https://www.anthropic.com/research/building-effective-agents"]],
  },
  {
    title: "Focused specialist delegation",
    shipped: "Domain specialists answer narrow questions and return compact evidence; they do not run competing investigations.",
    why: "Security work benefits from explicit decomposition and preserved global context without requiring a permanent swarm.",
    sources: [["PentestGPT", "https://www.usenix.org/conference/usenixsecurity24/presentation/deng"], ["PentestEval", "https://arxiv.org/abs/2512.14233"]],
  },
  {
    title: "Automatic attempt projection",
    shipped: "Every Session V2 tool settlement becomes an append-only attempt with hashes, timing, status, artifact path, and bounded observation.",
    why: "An inspectable action/observation stream survives context changes without asking the model to remember to log itself.",
    sources: [["OpenHands", "https://arxiv.org/abs/2407.16741"], ["Long-running harnesses", "https://www.anthropic.com/engineering/effective-harnesses-for-long-running-agents"]],
  },
  {
    title: "Observations are not findings",
    shipped: "Tool output, model hypotheses, and oracle-accepted findings are separate semantic levels.",
    why: "Environment interaction constrains hallucination and prevents imagined observations from silently becoming facts.",
    sources: [["EnIGMA", "https://arxiv.org/abs/2409.16165"], ["ReAct", "https://arxiv.org/abs/2210.03629"]],
  },
  {
    title: "Task-specific context cards",
    shipped: "The next turn sees the active branch, last three relevant attempts, lessons, artifact references, alternatives, and remaining budget.",
    why: "Small high-signal context and bounded retrieval outperform dumping full transcripts or whole artifacts into the prompt.",
    sources: [["Context engineering", "https://www.anthropic.com/engineering/effective-context-engineering-for-ai-agents"], ["SWE-agent", "https://arxiv.org/abs/2405.15793"]],
  },
  {
    title: "Reflection with a stopping rule",
    shipped: "Repeated or evidence-free attempts trigger one structured reflection, followed by one changed retry before branch switching.",
    why: "Short linguistic lessons can improve later trials, but retries must remain bounded to prevent loops.",
    sources: [["Reflexion", "https://arxiv.org/abs/2303.11366"], ["ExpeL", "https://arxiv.org/abs/2308.10144"]],
  },
  {
    title: "Executable verification boundary",
    shipped: "A candidate is solved only after a trusted digest or command oracle accepts; verifier output remains an artifact.",
    why: "Milestones and deterministic graders distinguish persuasive reports from executable progress and enable partial credit.",
    sources: [["Cybench", "https://arxiv.org/abs/2408.08926"], ["AutoPenBench", "https://arxiv.org/abs/2410.03225"], ["ExploitBench", "https://arxiv.org/abs/2605.14153"], ["BountyBench", "https://arxiv.org/abs/2505.15216"]],
  },
  {
    title: "Local, inspectable state",
    shipped: "Run snapshots, attempts, lessons, and raw artifacts stay under the workspace-local .penhub directory.",
    why: "Session V2 already provides durable history. Another database, queue, or orchestration service would duplicate the runtime boundary.",
    sources: [["OpenHands", "https://arxiv.org/abs/2407.16741"], ["Effective agents", "https://www.anthropic.com/research/building-effective-agents"]],
  },
  {
    title: "Recipes are deliberately late",
    shipped: "The runtime is ready for compact verified recipes, but retrieval remains isolated from held-out tasks and is not in the default loop.",
    why: "Experience transfer is useful, while challenge-family leakage can make capability claims meaningless.",
    sources: [["ExpeL", "https://arxiv.org/abs/2308.10144"], ["Voyager", "https://arxiv.org/abs/2305.16291"], ["EnIGMA", "https://arxiv.org/abs/2409.16165"]],
  },
]

const sources = [
  ["EnIGMA", "Interactive Tools Substantially Assist LM Agents in Finding Security Vulnerabilities", "https://arxiv.org/abs/2409.16165"],
  ["Plain agents", "Hacking CTFs with Plain Agents", "https://arxiv.org/abs/2412.02776"],
  ["PentestGPT", "Evaluating and Harnessing LLMs for Automated Penetration Testing", "https://www.usenix.org/conference/usenixsecurity24/presentation/deng"],
  ["PentestEval", "Benchmarking LLM-based Penetration Testing with Modular and Stage-Level Design", "https://arxiv.org/abs/2512.14233"],
  ["SWE-agent", "Agent-Computer Interfaces Enable Automated Software Engineering", "https://arxiv.org/abs/2405.15793"],
  ["ReAct", "Synergizing Reasoning and Acting in Language Models", "https://arxiv.org/abs/2210.03629"],
  ["Reflexion", "Language Agents with Verbal Reinforcement Learning", "https://arxiv.org/abs/2303.11366"],
  ["ExpeL", "LLM Agents Are Experiential Learners", "https://arxiv.org/abs/2308.10144"],
  ["OpenHands", "An Open Platform for AI Software Developers as Generalist Agents", "https://arxiv.org/abs/2407.16741"],
  ["Cybench", "A Framework for Evaluating Cybersecurity Capabilities and Risks of Language Models", "https://arxiv.org/abs/2408.08926"],
  ["AutoPenBench", "Benchmarking Generative Agents for Penetration Testing", "https://arxiv.org/abs/2410.03225"],
  ["ExploitBench", "A Capability Ladder Benchmark for LLM Cybersecurity Agents", "https://arxiv.org/abs/2605.14153"],
  ["BountyBench", "Dollar Impact of AI Agent Attackers and Defenders on Real-World Cybersecurity Systems", "https://arxiv.org/abs/2505.15216"],
  ["Voyager", "An Open-Ended Embodied Agent with Large Language Models", "https://arxiv.org/abs/2305.16291"],
  ["Agentless", "Demystifying LLM-based Software Engineering Agents", "https://arxiv.org/abs/2407.01489"],
  ["LATS", "Language Agent Tree Search Unifies Reasoning, Acting, and Planning", "https://arxiv.org/abs/2310.04406"],
  ["Anthropic", "Building Effective AI Agents", "https://www.anthropic.com/research/building-effective-agents"],
  ["Anthropic", "Effective Context Engineering for AI Agents", "https://www.anthropic.com/engineering/effective-context-engineering-for-ai-agents"],
  ["Anthropic", "Effective Harnesses for Long-Running Agents", "https://www.anthropic.com/engineering/effective-harnesses-for-long-running-agents"],
  ["Anthropic", "Demystifying Evals for AI Agents", "https://www.anthropic.com/engineering/demystifying-evals-for-ai-agents"],
]
---

<Base>
  <section class="relative overflow-hidden border-b border-line pt-18 pb-16 sm:pt-24 sm:pb-22">
    <div class="grid-noise pointer-events-none absolute inset-0"></div>
    <div class="site-shell relative grid items-end gap-12 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="reveal">
        <p class="eyebrow">OpenCode-derived security runtime</p>
        <h1 class="mt-5 max-w-4xl text-5xl leading-[0.98] font-semibold tracking-[-0.055em] text-white sm:text-7xl">
          Security agents should <span class="text-signal">prove</span> progress.
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-8 text-muted sm:text-xl">
          PenHub keeps one capable operator in control, gives it persistent security tools, preserves every experiment, and finishes only when an executable oracle agrees.
        </p>
        <div class="mt-9 flex flex-col gap-3 sm:flex-row">
          <a class="rounded-lg bg-signal px-5 py-3 text-center font-semibold text-white hover:bg-signal-deep" href="https://github.com/loegaire/penhub">View source ↗</a>
          <a class="rounded-lg border border-line bg-panel px-5 py-3 text-center font-semibold text-white hover:border-signal/60" href="#architecture">Explore architecture ↓</a>
        </div>
      </div>
      <div class="reveal reveal-delay rounded-2xl border border-line bg-panel/85 p-3 shadow-[0_30px_80px_rgb(0_0_0/45%)]">
        <div class="flex items-center gap-2 border-b border-line px-2 pb-3 font-mono text-[11px] text-muted">
          <span class="size-2 rounded-full bg-signal"></span>
          <span>RUN / ACTIVE BRANCH</span>
          <span class="ml-auto text-[#4eb37b]">ORACLE READY</span>
        </div>
        <div class="space-y-4 p-3 font-mono text-sm">
          <p class="text-muted">goal</p>
          <p>Obtain and independently verify the target objective.</p>
          <div class="signal-rule"></div>
          <div class="grid grid-cols-[5.5rem_1fr] gap-y-3 text-xs">
            <span class="text-muted">branch</span><span>test-auth-boundary</span>
            <span class="text-muted">next test</span><span>replay the smallest decisive request</span>
            <span class="text-muted">evidence</span><span class="text-[#4eb37b]">3 linked artifacts</span>
            <span class="text-muted">budget</span><span>18 actions · 6 turns</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="product" class="py-18 sm:py-24">
    <div class="site-shell">
      <div class="max-w-3xl">
        <p class="eyebrow">The product</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-5xl">A cockpit for evidence-backed security work.</h2>
        <p class="mt-5 text-lg leading-8 text-muted">CTF, source audit, binary exploitation, reverse engineering, cryptanalysis, and forensics share one durable session runtime and one consistent tool plane.</p>
      </div>
      <figure class="mt-10 overflow-hidden rounded-2xl border border-line bg-panel p-2 shadow-2xl">
        <img src={`${base}screenshots/session-cockpit.png`} alt="PenHub session cockpit with sessions, transcript, attack state, and file browser" class="w-full rounded-xl" loading="eager" />
        <figcaption class="px-3 py-3 font-mono text-xs text-muted">Live session cockpit · workspace state and raw evidence remain local</figcaption>
      </figure>
      <div class="mt-6 grid gap-6 lg:grid-cols-2">
        <figure class="overflow-hidden rounded-2xl border border-line bg-panel p-2">
          <img src={`${base}screenshots/evidence-view.png`} alt="PenHub evidence view showing observations and artifact references" class="w-full rounded-xl" loading="lazy" />
          <figcaption class="px-3 py-3 font-mono text-xs text-muted">Evidence view · observations remain distinct from verified findings</figcaption>
        </figure>
        <div class="grid gap-4 sm:grid-cols-2">
          {[
            ["54", "packaged security tools"],
            ["4", "persistent PTY operations"],
            ["3", "maximum open branches"],
            ["1", "reflection before switching"],
          ].map(([value, label]) => (
            <div class="rounded-2xl border border-line bg-panel p-6">
              <p class="font-mono text-4xl font-semibold text-signal">{value}</p>
              <p class="mt-3 text-sm leading-6 text-muted">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="architecture" class="border-y border-line bg-panel/45 py-18 sm:py-24">
    <div class="site-shell">
      <div class="grid gap-10 lg:grid-cols-[0.75fr_1.25fr]">
        <div>
          <p class="eyebrow">Runtime architecture</p>
          <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-5xl">One loop. Durable edges.</h2>
          <p class="mt-5 leading-7 text-muted">PenHub extends OpenCode Session V2 instead of creating a parallel platform. The provider loop, permissions, locations, tools, and event history remain authoritative.</p>
          <pre class="mt-7 overflow-x-auto rounded-xl border border-line bg-ink p-5 font-mono text-xs leading-6 text-[#c9cfcb]"><code>Session V2
  ↓
bounded operator
  ↓
raw tools + persistent PTY
  ↓
attempt projector + artifacts
  ↓
branch-specific context
  ↓
executable verifier</code></pre>
        </div>
        <ol class="grid gap-3 sm:grid-cols-2">
          {flow.map(([number, title, content]) => (
            <li class="rounded-xl border border-line bg-panel p-5">
              <span class="font-mono text-xs text-signal">{number}</span>
              <h3 class="mt-5 text-lg font-semibold text-white">{title}</h3>
              <p class="mt-2 text-sm leading-6 text-muted">{content}</p>
            </li>
          ))}
        </ol>
      </div>
      <div class="mt-14 grid gap-px overflow-hidden rounded-2xl border border-line bg-line md:grid-cols-3">
        {[
          ["Canonical tool plane", "Raw OCI tools, semantic conveniences, and interactive sessions all settle through OpenCode's Tool.make registry."],
          ["Workspace-local memory", "run.json is the compact snapshot; attempts and lessons are append-only; raw output stays under .penhub/artifacts."],
          ["Trusted finish line", "The model proposes a candidate. A digest or external command oracle decides whether the run is solved."],
        ].map(([title, content]) => (
          <article class="bg-panel p-7">
            <h3 class="font-semibold text-white">{title}</h3>
            <p class="mt-3 text-sm leading-6 text-muted">{content}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="decisions" class="py-18 sm:py-24">
    <div class="site-shell">
      <div class="max-w-3xl">
        <p class="eyebrow">Decision ledger</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-5xl">Every addition has a reason.</h2>
        <p class="mt-5 text-lg leading-8 text-muted">Research results are not directly comparable across models, tasks, budgets, or scaffolds. PenHub uses recurring patterns as design evidence—not as interchangeable performance claims.</p>
      </div>
      <div class="mt-12 space-y-4">
        {decisions.map((decision, index) => (
          <article class="grid gap-5 rounded-2xl border border-line bg-panel/75 p-6 lg:grid-cols-[3rem_0.8fr_1.2fr] lg:p-8">
            <span class="font-mono text-sm text-signal">{String(index + 1).padStart(2, "0")}</span>
            <div>
              <h3 class="text-xl font-semibold text-white">{decision.title}</h3>
              <p class="mt-3 text-sm leading-6 text-[#c9cfcb]">{decision.shipped}</p>
            </div>
            <div class="lg:border-l lg:border-line lg:pl-8">
              <p class="text-sm leading-6 text-muted">{decision.why}</p>
              <p class="mt-4 flex flex-wrap gap-2">
                {decision.sources.map(([label, href]) => (
                  <a class="rounded-full border border-signal/25 bg-signal/8 px-3 py-1 font-mono text-[11px] text-signal hover:border-signal" href={href}>{label} ↗</a>
                ))}
              </p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="border-y border-line bg-paper py-18 text-ink sm:py-24">
    <div class="site-shell grid gap-10 lg:grid-cols-[0.8fr_1.2fr]">
      <div>
        <p class="eyebrow">Deliberate exclusions</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-5xl">What PenHub does not need.</h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        {[
          ["No second orchestration platform", "Effective agents", "https://www.anthropic.com/research/building-effective-agents"],
          ["No autonomous swarm by default", "Agentless", "https://arxiv.org/abs/2407.01489"],
          ["No PostgreSQL, Redis, or Temporal", "OpenHands", "https://arxiv.org/abs/2407.16741"],
          ["No vector database in the core loop", "Context engineering", "https://www.anthropic.com/engineering/effective-context-engineering-for-ai-agents"],
          ["No model-authored verified facts", "EnIGMA", "https://arxiv.org/abs/2409.16165"],
          ["No full raw logs in model context", "SWE-agent", "https://arxiv.org/abs/2405.15793"],
          ["No MCTS without measured benefit", "LATS", "https://arxiv.org/abs/2310.04406"],
          ["No finish without verification", "ExploitBench", "https://arxiv.org/abs/2605.14153"],
        ].map(([item, source, href]) => (
          <div class="flex items-start gap-3 rounded-xl border border-black/12 bg-white/55 p-4 text-sm font-medium">
            <span class="mt-0.5 font-mono text-signal-deep">×</span>
            <span class="min-w-0 flex-1">{item}</span>
            <a class="font-mono text-[10px] text-signal-deep underline decoration-black/20 underline-offset-3" href={href}>{source} ↗</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="sources" class="py-18 sm:py-24">
    <div class="site-shell">
      <div class="max-w-3xl">
        <p class="eyebrow">Primary source library</p>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight text-white sm:text-5xl">Read the evidence.</h2>
        <p class="mt-5 leading-7 text-muted">Peer-reviewed security work, research preprints, public benchmark papers, and engineering reports from teams operating agent systems.</p>
      </div>
      <ol class="mt-10 grid gap-px overflow-hidden rounded-2xl border border-line bg-line md:grid-cols-2">
        {sources.map(([author, title, href], index) => (
          <li class="group bg-panel p-5 hover:bg-panel-soft">
            <a href={href} class="grid grid-cols-[2.5rem_1fr_auto] gap-3 no-underline">
              <span class="font-mono text-xs text-signal">{String(index + 1).padStart(2, "0")}</span>
              <span>
                <strong class="block text-sm text-white">{title}</strong>
                <span class="mt-1 block font-mono text-[11px] text-muted">{author}</span>
              </span>
              <span class="text-muted group-hover:text-signal">↗</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="pb-20 sm:pb-28">
    <div class="site-shell rounded-3xl border border-signal/35 bg-[linear-gradient(135deg,#251513,#0e1113_60%)] p-7 sm:p-12">
      <p class="eyebrow">Start locally</p>
      <div class="mt-4 grid min-w-0 gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
        <div class="min-w-0">
          <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-5xl">Clone. Install. Open the cockpit.</h2>
          <pre class="mt-7 max-w-full overflow-x-auto rounded-xl border border-white/10 bg-ink/75 p-5 font-mono text-sm leading-7 text-[#c9cfcb]"><code>git clone https://github.com/loegaire/penhub.git
cd penhub
bun install
bun run gui</code></pre>
        </div>
        <a class="rounded-lg bg-signal px-5 py-3 text-center font-semibold text-white hover:bg-signal-deep" href="https://github.com/loegaire/penhub#quick-start-gui-mode">Installation guide ↗</a>
      </div>
    </div>
  </section>
</Base>
