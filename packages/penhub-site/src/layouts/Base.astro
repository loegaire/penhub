---
import Footer from "../components/Footer.astro"
import Header from "../components/Header.astro"
import "../styles/global.css"

const base = import.meta.env.BASE_URL
const {
  title = "PenHub — Evidence-driven security agent",
  description = "One capable security operator with persistent tools, durable evidence, bounded retries, and executable verification.",
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#090b0d" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href={`${base}icon.png`} />
    <link rel="canonical" href="https://loegaire.github.io/penhub/" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content="https://loegaire.github.io/penhub/" />
    <meta property="og:image" content={`https://loegaire.github.io/penhub/screenshots/session-cockpit.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:z-100 focus:bg-signal focus:px-4 focus:py-2">Skip to content</a>
    <Header />
    <main id="main"><slot /></main>
    <Footer />
  </body>
</html>
