---
const base = import.meta.env.BASE_URL
const { compact = false } = Astro.props
---

<a href={base} class="inline-flex items-center gap-3 text-white no-underline" aria-label="PenHub home">
  <span class:list={["grid place-items-center rounded-lg border border-line bg-ink", compact ? "size-8" : "size-10"]}>
    <img src={`${base}icon.png`} alt="" class:list={[compact ? "size-5" : "size-6", "[image-rendering:pixelated]"]} />
  </span>
  <span class="font-mono text-sm font-bold tracking-[0.12em]">PEN<span class="text-signal">/</span>HUB</span>
</a>
