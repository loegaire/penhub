---
import Brand from "./Brand.astro"
const year = new Date().getFullYear()
---

<footer class="border-t border-line bg-panel/60 py-10">
  <div class="site-shell flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <Brand compact />
      <p class="mt-3 max-w-md text-sm text-muted">Built for authorized security work. Preserve evidence. Verify outcomes.</p>
    </div>
    <div class="text-sm text-muted sm:text-right">
      <p>© {year} PenHub contributors</p>
      <p class="mt-1">Site structure adapted from <a class="source-link" href="https://github.com/zeon-studio/astroplate">Astroplate</a> (MIT).</p>
    </div>
  </div>
</footer>
